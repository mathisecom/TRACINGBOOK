        "liquid_CiXtYE": {
          "type": "liquid",
          "settings": {
            "liquid": "<!--\n  Bloc de réassurance à placer sous le bouton \"Ajouter au panier\".\n  Compatible avec un bloc \"Liquid personnalisé\" Shopify.\n-->\n\n<style>\n  .product-reassurance {\n    --reassurance-color: #4b97f3;\n    --reassurance-text-color: #343434;\n    --reassurance-icon-size: 56px;\n    --reassurance-gap: 18px;\n\n    width: 100%;\n    margin-top: 20px;\n  }\n\n  .product-reassurance,\n  .product-reassurance * {\n    box-sizing: border-box;\n  }\n\n  .product-reassurance__grid {\n    display: grid;\n    grid-template-columns: repeat(3, minmax(0, 1fr));\n    gap: var(--reassurance-gap);\n    align-items: start;\n  }\n\n  .product-reassurance__item {\n    min-width: 0;\n    text-align: center;\n  }\n\n  .product-reassurance__icon {\n    display: grid;\n    width: var(--reassurance-icon-size);\n    height: var(--reassurance-icon-size);\n    margin: 0 auto 10px;\n    place-items: center;\n    color: var(--reassurance-color);\n    border: 3px solid currentColor;\n    border-radius: 50%;\n  }\n\n  .product-reassurance__icon svg {\n    width: 68%;\n    height: 68%;\n    display: block;\n  }\n\n  .product-reassurance__text {\n    margin: 0;\n    color: var(--reassurance-text-color);\n    font-size: 11px;\n    font-weight: 700;\n    line-height: 1.25;\n  }\n\n  @media screen and (max-width: 749px) {\n    .product-reassurance {\n      --reassurance-icon-size: 48px;\n      --reassurance-gap: 8px;\n      margin-top: 16px;\n    }\n\n    .product-reassurance__icon {\n      margin-bottom: 8px;\n      border-width: 2px;\n    }\n\n    .product-reassurance__text {\n      font-size: 12px;\n      line-height: 1.2;\n    }\n  }\n\n  @media screen and (max-width: 380px) {\n    .product-reassurance__text {\n      font-size: 11px;\n    }\n  }\n</style>\n\n<div class=\"product-reassurance\" role=\"list\" aria-label=\"Nos engagements\">\n  <div class=\"product-reassurance__grid\">\n\n    <div class=\"product-reassurance__item\" role=\"listitem\">\n      <div class=\"product-reassurance__icon\" aria-hidden=\"true\">\n        <svg viewBox=\"0 0 64 64\" fill=\"none\">\n          <path d=\"M8 30L55 10L42 53L29 37L8 30Z\" fill=\"currentColor\"/>\n          <path d=\"M29 37L55 10L20 32\" stroke=\"#ffffff\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          <path d=\"M29 37L27 49L35 42\" fill=\"currentColor\"/>\n        </svg>\n      </div>\n      <p class=\"product-reassurance__text\">\n        Livraison<br>48h\n      </p>\n    </div>\n\n    <div class=\"product-reassurance__item\" role=\"listitem\">\n      <div class=\"product-reassurance__icon\" aria-hidden=\"true\">\n        <svg viewBox=\"0 0 64 64\" fill=\"none\">\n          <rect x=\"12\" y=\"15\" width=\"40\" height=\"38\" rx=\"4\" stroke=\"currentColor\" stroke-width=\"4\"/>\n          <path d=\"M12 25H52\" stroke=\"currentColor\" stroke-width=\"4\"/>\n          <path d=\"M21 10V20M43 10V20\" stroke=\"currentColor\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n          <path d=\"M20 32H25M30 32H35M40 32H45M20 40H25M30 40H35M40 40H45M20 48H25M30 48H35M40 48H45\"\n                stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n        </svg>\n      </div>\n      <p class=\"product-reassurance__text\">\n        Satisfait ou remboursé<br>\n      </p>\n    </div>\n\n    <div class=\"product-reassurance__item\" role=\"listitem\">\n      <div class=\"product-reassurance__icon\" aria-hidden=\"true\">\n        <svg viewBox=\"0 0 64 64\" fill=\"none\">\n          <path d=\"M26 18H45C53 18 58 24 58 32C58 40 52 46 44 46H32\"\n                stroke=\"currentColor\" stroke-width=\"5\" stroke-linecap=\"round\"/>\n          <path d=\"M31 8L20 18L31 28\" fill=\"currentColor\"/>\n          <path d=\"M12 33L26 27L40 33L26 39L12 33Z\" fill=\"currentColor\"/>\n          <path d=\"M12 33V45L26 53V39L12 33ZM40 33V45L26 53V39L40 33Z\"\n                fill=\"currentColor\" opacity=\"0.75\"/>\n        </svg>\n      </div>\n      <p class=\"product-reassurance__text\">\n        Retours<br>simplifiés\n      </p>\n    </div>\n\n  </div>\n</div>"
          }
        },
