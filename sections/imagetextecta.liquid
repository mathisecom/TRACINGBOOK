{%- liquid
  assign section_anchor = section.settings.anchor_id | strip
  assign image_alt = section.settings.image_alt | strip
  if image_alt == blank and section.settings.image != blank
    assign image_alt = section.settings.image.alt
  endif
-%}

{%- if section.settings.use_grandstander_heading -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Grandstander:wght@500;600;700;800&display=swap" rel="stylesheet">
{%- endif -%}

<section
  id="{% if section_anchor != blank %}{{ section_anchor | escape }}{% else %}image-texte-cta-{{ section.id }}{% endif %}"
  class="image-text-cta image-text-cta--{{ section.id }} image-text-cta--image-{{ section.settings.image_position }}"
>
  <div class="image-text-cta__container">
    <div class="image-text-cta__grid">
      <div class="image-text-cta__visual">
        <div class="image-text-cta__image-wrap">
          {%- if section.settings.image != blank -%}
            <img
              class="image-text-cta__image"
              src="{{ section.settings.image | image_url: width: 1400 }}"
              srcset="
                {{ section.settings.image | image_url: width: 480 }} 480w,
                {{ section.settings.image | image_url: width: 750 }} 750w,
                {{ section.settings.image | image_url: width: 1000 }} 1000w,
                {{ section.settings.image | image_url: width: 1400 }} 1400w
              "
              sizes="(max-width: 749px) calc(100vw - 36px), {{ section.settings.image_width_percent }}vw"
              width="{{ section.settings.image.width }}"
              height="{{ section.settings.image.height }}"
              alt="{{ image_alt | escape }}"
              loading="lazy"
            >
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'image-text-cta__placeholder' }}
          {%- endif -%}

          {%- if section.settings.show_decorations -%}
            <svg
              class="image-text-cta__rays image-text-cta__rays--top"
              viewBox="0 0 90 90"
              aria-hidden="true"
              focusable="false"
            >
              <path d="M48 7L52 34" />
              <path d="M18 20L36 39" />
              <path d="M7 50L34 54" />
            </svg>

            <svg
              class="image-text-cta__rays image-text-cta__rays--bottom"
              viewBox="0 0 90 90"
              aria-hidden="true"
              focusable="false"
            >
              <path d="M48 7L52 34" />
              <path d="M18 20L36 39" />
              <path d="M7 50L34 54" />
            </svg>
          {%- endif -%}
        </div>
      </div>

      <div class="image-text-cta__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="image-text-cta__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <{{ section.settings.heading_tag }} class="image-text-cta__heading">
            {{ section.settings.heading }}
          </{{ section.settings.heading_tag }}>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="image-text-cta__text rte">
            {{ section.settings.text }}
          </div>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <a
            class="image-text-cta__button"
            {% if section.settings.button_link != blank %}
              href="{{ section.settings.button_link }}"
            {% else %}
              role="link" aria-disabled="true"
            {% endif %}
            {% if section.settings.open_new_tab and section.settings.button_link != blank %}
              target="_blank" rel="noopener noreferrer"
            {% endif %}
          >
            {{ section.settings.button_label | escape }}
            {%- if section.settings.show_button_arrow -%}
              <svg viewBox="0 0 20 20" aria-hidden="true" focusable="false">
                <path d="M4 10h11M11 6l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            {%- endif -%}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% style %}
  .image-text-cta--{{ section.id }} {
    --section-bg: {{ section.settings.background_color }};
    --heading-color: {{ section.settings.heading_color }};
    --text-color: {{ section.settings.text_color }};
    --eyebrow-color: {{ section.settings.eyebrow_color }};
    --button-bg: {{ section.settings.button_background }};
    --button-color: {{ section.settings.button_text_color }};
    --button-border: {{ section.settings.button_border_color }};
    --button-bg-hover: {{ section.settings.button_background_hover }};
    --button-color-hover: {{ section.settings.button_text_color_hover }};
    --decoration-color: {{ section.settings.decoration_color }};
    --image-radius: {{ section.settings.image_radius }}px;
    --content-gap: {{ section.settings.content_gap }}px;
    --image-column: {{ section.settings.image_width_percent }}%;
    --image-ratio: {{ section.settings.image_ratio }};

    width: 100%;
    overflow: hidden;
    background: var(--section-bg);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .image-text-cta--{{ section.id }} *,
  .image-text-cta--{{ section.id }} *::before,
  .image-text-cta--{{ section.id }} *::after {
    box-sizing: border-box;
  }

  .image-text-cta--{{ section.id }} .image-text-cta__container {
    width: min(
      calc(100% - ({{ section.settings.side_padding }}px * 2)),
      {{ section.settings.content_width }}px
    );
    margin: 0 auto;
  }

  .image-text-cta--{{ section.id }} .image-text-cta__grid {
    display: grid;
    grid-template-columns: minmax(0, var(--image-column)) minmax(0, 1fr);
    align-items: {{ section.settings.vertical_alignment }};
    gap: var(--content-gap);
  }

  .image-text-cta--{{ section.id }}.image-text-cta--image-right .image-text-cta__visual {
    order: 2;
  }

  .image-text-cta--{{ section.id }}.image-text-cta--image-right .image-text-cta__content {
    order: 1;
  }

  .image-text-cta--{{ section.id }} .image-text-cta__visual {
    min-width: 0;
  }

  .image-text-cta--{{ section.id }} .image-text-cta__image-wrap {
    position: relative;
    width: 100%;
  }

  .image-text-cta--{{ section.id }} .image-text-cta__image,
  .image-text-cta--{{ section.id }} .image-text-cta__placeholder {
    display: block;
    width: 100%;
    aspect-ratio: var(--image-ratio);
    border-radius: var(--image-radius);
    object-fit: {{ section.settings.image_fit }};
    object-position: {{ section.settings.image_focal_point }};
    background: {{ section.settings.placeholder_background }};
  }

  .image-text-cta--{{ section.id }} .image-text-cta__placeholder {
    padding: 40px;
  }

  .image-text-cta--{{ section.id }} .image-text-cta__rays {
    position: absolute;
    z-index: 2;
    width: {{ section.settings.decoration_size }}px;
    height: {{ section.settings.decoration_size }}px;
    overflow: visible;
    pointer-events: none;
  }

  .image-text-cta--{{ section.id }} .image-text-cta__rays path {
    fill: none;
    stroke: var(--decoration-color);
    stroke-width: {{ section.settings.decoration_thickness }};
    stroke-linecap: round;
  }

  .image-text-cta--{{ section.id }} .image-text-cta__rays--top {
    top: -{{ section.settings.decoration_offset }}px;
    left: -{{ section.settings.decoration_offset }}px;
  }

  .image-text-cta--{{ section.id }} .image-text-cta__rays--bottom {
    right: -{{ section.settings.decoration_offset }}px;
    bottom: -{{ section.settings.decoration_offset }}px;
    transform: rotate(180deg);
  }

  .image-text-cta--{{ section.id }} .image-text-cta__content {
    max-width: {{ section.settings.text_max_width }}px;
    text-align: {{ section.settings.text_alignment }};
  }

  .image-text-cta--{{ section.id }} .image-text-cta__eyebrow {
    margin: 0 0 {{ section.settings.eyebrow_spacing }}px;
    color: var(--eyebrow-color);
    font-size: {{ section.settings.eyebrow_size }}px;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .image-text-cta--{{ section.id }} .image-text-cta__heading {
    margin: 0;
    color: var(--heading-color);
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    line-height: {{ section.settings.heading_line_height | divided_by: 100.0 }};
    letter-spacing: {{ section.settings.heading_letter_spacing | divided_by: 10.0 }}px;
  }

  {%- if section.settings.use_grandstander_heading -%}
    .image-text-cta--{{ section.id }} .image-text-cta__heading {
      font-family: "Grandstander", sans-serif;
    }
  {%- endif -%}

  .image-text-cta--{{ section.id }} .image-text-cta__text {
    margin-top: {{ section.settings.text_spacing }}px;
    color: var(--text-color);
    font-size: {{ section.settings.text_size }}px;
    font-weight: {{ section.settings.text_weight }};
    line-height: {{ section.settings.text_line_height | divided_by: 100.0 }};
  }

  .image-text-cta--{{ section.id }} .image-text-cta__text > :first-child {
    margin-top: 0;
  }

  .image-text-cta--{{ section.id }} .image-text-cta__text > :last-child {
    margin-bottom: 0;
  }

  .image-text-cta--{{ section.id }} .image-text-cta__text strong {
    color: var(--heading-color);
    font-weight: 700;
  }

  .image-text-cta--{{ section.id }} .image-text-cta__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    min-height: {{ section.settings.button_height }}px;
    margin-top: {{ section.settings.button_spacing }}px;
    padding: 12px {{ section.settings.button_horizontal_padding }}px;
    color: var(--button-color);
    background: var(--button-bg);
    border: {{ section.settings.button_border_width }}px solid var(--button-border);
    border-radius: {{ section.settings.button_radius }}px;
    font-size: {{ section.settings.button_text_size }}px;
    font-weight: 700;
    line-height: 1.2;
    text-align: center;
    text-decoration: none;
    transition:
      transform 180ms ease,
      background-color 180ms ease,
      color 180ms ease,
      border-color 180ms ease;
  }

  .image-text-cta--{{ section.id }} .image-text-cta__button svg {
    width: 20px;
    height: 20px;
    flex: 0 0 auto;
  }

  .image-text-cta--{{ section.id }} .image-text-cta__button:hover {
    color: var(--button-color-hover);
    background: var(--button-bg-hover);
    transform: translateY(-2px);
  }

  .image-text-cta--{{ section.id }} .image-text-cta__button[aria-disabled="true"] {
    cursor: default;
    opacity: 0.65;
  }

  @media screen and (max-width: 989px) {
    .image-text-cta--{{ section.id }} {
      --content-gap: {{ section.settings.content_gap_tablet }}px;
    }

    .image-text-cta--{{ section.id }} .image-text-cta__grid {
      grid-template-columns: minmax(0, 48%) minmax(0, 1fr);
    }

    .image-text-cta--{{ section.id }} .image-text-cta__heading {
      font-size: {{ section.settings.heading_size_tablet }}px;
    }

    .image-text-cta--{{ section.id }} .image-text-cta__text {
      font-size: {{ section.settings.text_size_tablet }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .image-text-cta--{{ section.id }} {
      --content-gap: {{ section.settings.content_gap_mobile }}px;
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    .image-text-cta--{{ section.id }} .image-text-cta__container {
      width: min(
        calc(100% - ({{ section.settings.side_padding_mobile }}px * 2)),
        {{ section.settings.content_width }}px
      );
    }

    .image-text-cta--{{ section.id }} .image-text-cta__grid {
      grid-template-columns: 1fr;
    }

    .image-text-cta--{{ section.id }} .image-text-cta__visual,
    .image-text-cta--{{ section.id }} .image-text-cta__content {
      order: initial;
    }

    {%- if section.settings.mobile_content_first -%}
      .image-text-cta--{{ section.id }} .image-text-cta__content {
        order: 1;
      }

      .image-text-cta--{{ section.id }} .image-text-cta__visual {
        order: 2;
      }
    {%- else -%}
      .image-text-cta--{{ section.id }} .image-text-cta__visual {
        order: 1;
      }

      .image-text-cta--{{ section.id }} .image-text-cta__content {
        order: 2;
      }
    {%- endif -%}

    .image-text-cta--{{ section.id }} .image-text-cta__content {
      max-width: 100%;
      text-align: {{ section.settings.text_alignment_mobile }};
    }

    .image-text-cta--{{ section.id }} .image-text-cta__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
      line-height: {{ section.settings.heading_line_height_mobile | divided_by: 100.0 }};
    }

    .image-text-cta--{{ section.id }} .image-text-cta__text {
      font-size: {{ section.settings.text_size_mobile }}px;
      line-height: {{ section.settings.text_line_height_mobile | divided_by: 100.0 }};
    }

    .image-text-cta--{{ section.id }} .image-text-cta__button {
      width: {% if section.settings.button_full_width_mobile %}100%{% else %}auto{% endif %};
    }

    .image-text-cta--{{ section.id }} .image-text-cta__rays {
      width: {{ section.settings.decoration_size_mobile }}px;
      height: {{ section.settings.decoration_size_mobile }}px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .image-text-cta--{{ section.id }} .image-text-cta__button {
      transition: none;
    }

    .image-text-cta--{{ section.id }} .image-text-cta__button:hover {
      transform: none;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Image texte et CTA",
  "tag": "section",
  "class": "section-image-texte-cta",
  "settings": [
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Texte alternatif de l’image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Petit titre"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Titre",
      "default": "Découvrez notre Cahier de Pratique Magique"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Balise du titre",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texte",
      "default": "<p>Bien plus qu’un simple cahier d’écriture, ce support ludique aide votre enfant à <strong>développer sa motricité fine, sa concentration et le contrôle du stylo</strong>.</p><p>Grâce à ses pages effaçables, il peut recommencer les exercices encore et encore, apprendre à son rythme et progresser avec confiance.</p><p><strong>Une activité éducative, réutilisable et inspirée de la pédagogie Montessori.</strong></p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texte du bouton",
      "default": "Découvrir le cahier"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Lien du bouton"
    },
    {
      "type": "checkbox",
      "id": "open_new_tab",
      "label": "Ouvrir le lien dans un nouvel onglet",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_button_arrow",
      "label": "Afficher la flèche du bouton",
      "default": true
    },
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Identifiant d’ancrage",
      "info": "Facultatif. Exemple : decouvrir-le-cahier"
    },

    {
      "type": "header",
      "content": "Mise en page"
    },
    {
      "type": "range",
      "id": "content_width",
      "min": 900,
      "max": 1800,
      "step": 50,
      "unit": "px",
      "label": "Largeur maximale",
      "default": 1400
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Position de l’image sur ordinateur",
      "options": [
        { "value": "left", "label": "À gauche" },
        { "value": "right", "label": "À droite" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "image_width_percent",
      "min": 35,
      "max": 60,
      "step": 1,
      "unit": "%",
      "label": "Largeur de l’image",
      "default": 45
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Alignement vertical",
      "options": [
        { "value": "start", "label": "En haut" },
        { "value": "center", "label": "Au centre" },
        { "value": "end", "label": "En bas" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "content_gap",
      "min": 20,
      "max": 140,
      "step": 5,
      "unit": "px",
      "label": "Espace entre l’image et le texte",
      "default": 60
    },
    {
      "type": "range",
      "id": "content_gap_tablet",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Espace sur tablette",
      "default": 40
    },
    {
      "type": "range",
      "id": "content_gap_mobile",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Espace sur mobile",
      "default": 35
    },
    {
      "type": "checkbox",
      "id": "mobile_content_first",
      "label": "Afficher le texte avant l’image sur mobile",
      "default": false
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alignement du texte sur ordinateur",
      "options": [
        { "value": "left", "label": "À gauche" },
        { "value": "center", "label": "Centré" },
        { "value": "right", "label": "À droite" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "text_alignment_mobile",
      "label": "Alignement du texte sur mobile",
      "options": [
        { "value": "left", "label": "À gauche" },
        { "value": "center", "label": "Centré" },
        { "value": "right", "label": "À droite" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "text_max_width",
      "min": 400,
      "max": 900,
      "step": 25,
      "unit": "px",
      "label": "Largeur maximale du texte",
      "default": 650
    },

    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Format de l’image",
      "options": [
        { "value": "1 / 1", "label": "Carré" },
        { "value": "4 / 3", "label": "4:3" },
        { "value": "3 / 2", "label": "3:2" },
        { "value": "16 / 10", "label": "16:10" },
        { "value": "16 / 9", "label": "16:9" }
      ],
      "default": "4 / 3"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Ajustement de l’image",
      "options": [
        { "value": "cover", "label": "Recadrer pour remplir" },
        { "value": "contain", "label": "Afficher l’image entière" }
      ],
      "default": "cover"
    },
    {
      "type": "select",
      "id": "image_focal_point",
      "label": "Position de l’image",
      "options": [
        { "value": "center center", "label": "Centre" },
        { "value": "center top", "label": "Haut" },
        { "value": "center bottom", "label": "Bas" },
        { "value": "left center", "label": "Gauche" },
        { "value": "right center", "label": "Droite" }
      ],
      "default": "center center"
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Arrondi de l’image",
      "default": 38
    },
    {
      "type": "color",
      "id": "placeholder_background",
      "label": "Fond de l’image de démonstration",
      "default": "#eee9df"
    },

    {
      "type": "header",
      "content": "Décorations"
    },
    {
      "type": "checkbox",
      "id": "show_decorations",
      "label": "Afficher les petits rayons décoratifs",
      "default": true
    },
    {
      "type": "color",
      "id": "decoration_color",
      "label": "Couleur des décorations",
      "default": "#f2c94c"
    },
    {
      "type": "range",
      "id": "decoration_size",
      "min": 40,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Taille des décorations",
      "default": 75
    },
    {
      "type": "range",
      "id": "decoration_size_mobile",
      "min": 30,
      "max": 90,
      "step": 5,
      "unit": "px",
      "label": "Taille sur mobile",
      "default": 55
    },
    {
      "type": "range",
      "id": "decoration_offset",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Décalage des décorations",
      "default": 12
    },
    {
      "type": "range",
      "id": "decoration_thickness",
      "min": 3,
      "max": 9,
      "step": 1,
      "unit": "px",
      "label": "Épaisseur des décorations",
      "default": 6
    },

    {
      "type": "header",
      "content": "Titre et texte"
    },
    {
      "type": "checkbox",
      "id": "use_grandstander_heading",
      "label": "Utiliser Grandstander pour le titre",
      "default": true
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 28,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Taille du titre",
      "default": 42
    },
    {
      "type": "range",
      "id": "heading_size_tablet",
      "min": 26,
      "max": 56,
      "step": 2,
      "unit": "px",
      "label": "Taille du titre sur tablette",
      "default": 36
    },
