{%- liquid
  assign shadow_alpha = section.settings.shadow_opacity | times: 0.01
  assign section_anchor = section.settings.anchor_id | strip
-%}

{%- if section.settings.font_mode != 'theme' -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Grandstander:wght@400;500;600;700;800&display=swap" rel="stylesheet">
{%- endif -%}

<section
  id="{% if section_anchor != blank %}{{ section_anchor | escape }}{% else %}benefices-cahier-{{ section.id }}{% endif %}"
  class="magic-benefits magic-benefits--{{ section.id }} magic-benefits--font-{{ section.settings.font_mode }}"
>
  <div class="magic-benefits__container">
    {%- if section.settings.heading != blank -%}
      <{{ section.settings.heading_tag }} class="magic-benefits__heading">
        {{ section.settings.heading }}
      </{{ section.settings.heading_tag }}>
    {%- endif -%}

    {%- if section.settings.intro != blank -%}
      <div class="magic-benefits__intro rte">
        {{ section.settings.intro }}
      </div>
    {%- endif -%}

    <div class="magic-benefits__grid">
      {%- for block in section.blocks -%}
        <article
          class="magic-benefits__card"
          style="--card-rotation: {{ block.settings.rotation }}deg;"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.show_badge -%}
            <div class="magic-benefits__badge" aria-hidden="true">
              {%- if block.settings.icon_image != blank -%}
                <img
                  class="magic-benefits__badge-image"
                  src="{{ block.settings.icon_image | image_url: width: 160 }}"
                  srcset="
                    {{ block.settings.icon_image | image_url: width: 80 }} 80w,
                    {{ block.settings.icon_image | image_url: width: 120 }} 120w,
                    {{ block.settings.icon_image | image_url: width: 160 }} 160w
                  "
                  sizes="80px"
                  width="{{ block.settings.icon_image.width }}"
                  height="{{ block.settings.icon_image.height }}"
                  alt=""
                  loading="lazy"
                >
              {%- else -%}
                <svg
                  class="magic-benefits__check"
                  viewBox="0 0 24 24"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M5 12.5L9.3 17L19 7"
                    stroke="currentColor"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              {%- endif -%}
            </div>
          {%- endif -%}

          <div class="magic-benefits__content">
            {%- if block.settings.title != blank -%}
              <h3 class="magic-benefits__title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <div class="magic-benefits__text rte">
                {{ block.settings.text }}
              </div>
            {%- endif -%}

            {%- if block.settings.link_label != blank and block.settings.link != blank -%}
              <a class="magic-benefits__link" href="{{ block.settings.link }}">
                {{ block.settings.link_label | escape }}
              </a>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% style %}
  .magic-benefits--{{ section.id }} {
    --section-background: {{ section.settings.background_color }};
    --heading-color: {{ section.settings.heading_color }};
    --intro-color: {{ section.settings.intro_color }};
    --card-background: {{ section.settings.card_background }};
    --card-border-color: {{ section.settings.card_border_color }};
    --card-title-color: {{ section.settings.card_title_color }};
    --card-text-color: {{ section.settings.card_text_color }};
    --badge-background: {{ section.settings.badge_background }};
    --badge-color: {{ section.settings.badge_color }};
    --link-color: {{ section.settings.link_color }};
    --card-radius: {{ section.settings.card_radius }}px;
    --card-border-width: {{ section.settings.card_border_width }}px;
    --card-min-height: {{ section.settings.card_min_height }}px;
    --badge-size: {{ section.settings.badge_size }}px;
    --grid-gap: {{ section.settings.grid_gap }}px;
    --card-padding-x: {{ section.settings.card_padding_x }}px;
    --card-padding-y: {{ section.settings.card_padding_y }}px;

    width: 100%;
    background: var(--section-background);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    overflow: hidden;
  }

  .magic-benefits--{{ section.id }} *,
  .magic-benefits--{{ section.id }} *::before,
  .magic-benefits--{{ section.id }} *::after {
    box-sizing: border-box;
  }

  .magic-benefits--{{ section.id }}.magic-benefits--font-all {
    font-family: "Grandstander", sans-serif;
  }

  .magic-benefits--{{ section.id }}.magic-benefits--font-headings .magic-benefits__heading,
  .magic-benefits--{{ section.id }}.magic-benefits--font-headings .magic-benefits__title,
  .magic-benefits--{{ section.id }}.magic-benefits--font-headings .magic-benefits__link {
    font-family: "Grandstander", sans-serif;
  }

  .magic-benefits--{{ section.id }} .magic-benefits__container {
    width: min(
      calc(100% - ({{ section.settings.side_padding }}px * 2)),
      {{ section.settings.content_width }}px
    );
    margin: 0 auto;
  }

  .magic-benefits--{{ section.id }} .magic-benefits__heading {
    max-width: {{ section.settings.heading_max_width }}px;
    margin: 0 auto;
    color: var(--heading-color);
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    line-height: {{ section.settings.heading_line_height | divided_by: 100.0 }};
    letter-spacing: {{ section.settings.heading_letter_spacing | divided_by: 10.0 }}px;
    text-align: {{ section.settings.text_alignment }};
  }

  .magic-benefits--{{ section.id }} .magic-benefits__intro {
    max-width: {{ section.settings.intro_max_width }}px;
    margin: {{ section.settings.intro_margin_top }}px auto 0;
    color: var(--intro-color);
    font-size: {{ section.settings.intro_size }}px;
    line-height: {{ section.settings.intro_line_height | divided_by: 100.0 }};
    text-align: {{ section.settings.text_alignment }};
  }

  .magic-benefits--{{ section.id }} .magic-benefits__intro > :first-child,
  .magic-benefits--{{ section.id }} .magic-benefits__text > :first-child {
    margin-top: 0;
  }

  .magic-benefits--{{ section.id }} .magic-benefits__intro > :last-child,
  .magic-benefits--{{ section.id }} .magic-benefits__text > :last-child {
    margin-bottom: 0;
  }

  .magic-benefits--{{ section.id }} .magic-benefits__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    gap: var(--grid-gap);
    align-items: stretch;
    margin-top: {{ section.settings.cards_margin_top }}px;
    padding-top: calc(var(--badge-size) / 2);
  }

  .magic-benefits--{{ section.id }} .magic-benefits__card {
    position: relative;
    display: flex;
    min-width: 0;
    min-height: var(--card-min-height);
    padding:
      calc(var(--card-padding-y) + (var(--badge-size) / 4))
      var(--card-padding-x)
      var(--card-padding-y);
    background: var(--card-background);
    border: var(--card-border-width) solid var(--card-border-color);
    border-radius: var(--card-radius);
    box-shadow:
      {{ section.settings.shadow_x }}px
      {{ section.settings.shadow_y }}px
      {{ section.settings.shadow_blur }}px
      {{ section.settings.shadow_spread }}px
      {{ section.settings.shadow_color | color_modify: 'alpha', shadow_alpha }};
    transform: rotate(var(--card-rotation));
    transition: transform 220ms ease, box-shadow 220ms ease;
  }

  .magic-benefits--{{ section.id }} .magic-benefits__card:hover {
    {%- if section.settings.enable_hover -%}
      transform: rotate(var(--card-rotation)) translateY(-{{ section.settings.hover_lift }}px);
    {%- endif -%}
  }

  .magic-benefits--{{ section.id }} .magic-benefits__content {
    width: 100%;
    margin: auto;
    text-align: {{ section.settings.card_alignment }};
  }

  .magic-benefits--{{ section.id }} .magic-benefits__badge {
    position: absolute;
    z-index: 2;
    top: calc(var(--badge-size) / -2);
    left: 50%;
    display: grid;
    width: var(--badge-size);
    height: var(--badge-size);
    place-items: center;
    overflow: hidden;
    color: var(--badge-color);
    background: var(--badge-background);
    border: {{ section.settings.badge_border_width }}px solid {{ section.settings.badge_border_color }};
    border-radius: 50%;
    transform: translateX(-50%);
  }

  .magic-benefits--{{ section.id }} .magic-benefits__check {
    width: {{ section.settings.check_size }}%;
    height: {{ section.settings.check_size }}%;
  }

  .magic-benefits--{{ section.id }} .magic-benefits__badge-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .magic-benefits--{{ section.id }} .magic-benefits__title {
    margin: 0;
    color: var(--card-title-color);
    font-size: {{ section.settings.card_title_size }}px;
    font-weight: {{ section.settings.card_title_weight }};
    line-height: {{ section.settings.card_title_line_height | divided_by: 100.0 }};
  }

  .magic-benefits--{{ section.id }} .magic-benefits__text {
    margin-top: {{ section.settings.text_margin_top }}px;
    color: var(--card-text-color);
    font-size: {{ section.settings.card_text_size }}px;
    font-weight: {{ section.settings.card_text_weight }};
    line-height: {{ section.settings.card_text_line_height | divided_by: 100.0 }};
  }

  .magic-benefits--{{ section.id }} .magic-benefits__link {
    display: inline-block;
    margin-top: {{ section.settings.link_margin_top }}px;
    color: var(--link-color);
    font-size: {{ section.settings.link_size }}px;
    font-weight: 700;
    text-underline-offset: 4px;
  }

  @media screen and (max-width: 989px) {
    .magic-benefits--{{ section.id }} .magic-benefits__grid {
      grid-template-columns: repeat({{ section.settings.columns_tablet }}, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .magic-benefits--{{ section.id }} {
      --card-min-height: {{ section.settings.card_min_height_mobile }}px;
      --badge-size: {{ section.settings.badge_size_mobile }}px;
      --grid-gap: {{ section.settings.grid_gap_mobile }}px;
      --card-padding-x: {{ section.settings.card_padding_x_mobile }}px;
      --card-padding-y: {{ section.settings.card_padding_y_mobile }}px;

      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    .magic-benefits--{{ section.id }} .magic-benefits__container {
      width: min(
        calc(100% - ({{ section.settings.side_padding_mobile }}px * 2)),
        {{ section.settings.content_width }}px
      );
    }

    .magic-benefits--{{ section.id }} .magic-benefits__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
      line-height: {{ section.settings.heading_line_height_mobile | divided_by: 100.0 }};
    }

    .magic-benefits--{{ section.id }} .magic-benefits__intro {
      font-size: {{ section.settings.intro_size_mobile }}px;
    }

    .magic-benefits--{{ section.id }} .magic-benefits__grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, minmax(0, 1fr));
      margin-top: {{ section.settings.cards_margin_top_mobile }}px;
    }

    .magic-benefits--{{ section.id }} .magic-benefits__title {
      font-size: {{ section.settings.card_title_size_mobile }}px;
    }

    .magic-benefits--{{ section.id }} .magic-benefits__text {
      font-size: {{ section.settings.card_text_size_mobile }}px;
    }

    {%- if section.settings.remove_rotation_mobile -%}
      .magic-benefits--{{ section.id }} .magic-benefits__card,
      .magic-benefits--{{ section.id }} .magic-benefits__card:hover {
        transform: none;
      }
    {%- endif -%}
  }

  @media (prefers-reduced-motion: reduce) {
    .magic-benefits--{{ section.id }} .magic-benefits__card {
      transition: none;
    }

    .magic-benefits--{{ section.id }} .magic-benefits__card:hover {
      transform: rotate(var(--card-rotation));
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Bénéfices cahier",
  "tag": "section",
  "class": "section-benefices-cahier",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Titre",
      "default": "Pourquoi ce cahier magique fait toute la différence"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Balise du titre",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Texte d’introduction"
    },
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Identifiant d’ancrage",
      "info": "Facultatif. Exemple : benefices-cahier"
    },

    {
      "type": "header",
      "content": "Mise en page"
    },
    {
      "type": "range",
      "id": "content_width",
      "min": 800,
      "max": 1800,
      "step": 50,
      "unit": "px",
      "label": "Largeur maximale",
      "default": 1500
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Colonnes sur ordinateur",
      "options": [
        { "value": "2", "label": "2 colonnes" },
        { "value": "3", "label": "3 colonnes" },
        { "value": "4", "label": "4 colonnes" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "columns_tablet",
      "label": "Colonnes sur tablette",
      "options": [
        { "value": "1", "label": "1 colonne" },
        { "value": "2", "label": "2 colonnes" },
        { "value": "3", "label": "3 colonnes" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Colonnes sur mobile",
      "options": [
        { "value": "1", "label": "1 colonne" },
        { "value": "2", "label": "2 colonnes" }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Espace entre les cartes",
      "default": 40
    },
    {
      "type": "range",
      "id": "grid_gap_mobile",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Espace entre les cartes sur mobile",
      "default": 40
    },
    {
      "type": "range",
      "id": "cards_margin_top",
      "min": 20,
      "max": 140,
      "step": 5,
      "unit": "px",
      "label": "Espace avant les cartes",
      "default": 85
    },
    {
      "type": "range",
      "id": "cards_margin_top_mobile",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Espace avant les cartes sur mobile",
      "default": 55
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Alignement du titre",
      "options": [
        { "value": "left", "label": "Gauche" },
        { "value": "center", "label": "Centré" },
        { "value": "right", "label": "Droite" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "card_alignment",
      "label": "Alignement dans les cartes",
      "options": [
        { "value": "left", "label": "Gauche" },
        { "value": "center", "label": "Centré" },
        { "value": "right", "label": "Droite" }
      ],
      "default": "center"
    },

    {
      "type": "header",
      "content": "Espacements de la section"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 5,
      "unit": "px",
      "label": "Marge supérieure",
      "default": 55
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 5,
      "unit": "px",
      "label": "Marge inférieure",
      "default": 70
    },
    {
      "type": "range",
      "id": "side_padding",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Marges latérales",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Marge supérieure sur mobile",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Marge inférieure sur mobile",
      "default": 45
    },
    {
      "type": "range",
      "id": "side_padding_mobile",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Marges latérales sur mobile",
      "default": 18
    },

    {
      "type": "header",
      "content": "Police et titre"
    },
    {
      "type": "select",
      "id": "font_mode",
      "label": "Police Grandstander",
      "options": [
        { "value": "all", "label": "Sur tout le texte" },
        { "value": "headings", "label": "Titres uniquement" },
        { "value": "theme", "label": "Utiliser la police du thème" }
      ],
      "default": "all"
    },
    {
      "type": "range",
      "id": "heading_max_width",
      "min": 500,
      "max": 1400,
      "step": 50,
      "unit": "px",
      "label": "Largeur maximale du titre",
      "default": 1000
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 28,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Taille du titre",
      "default": 50
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 22,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Taille du titre sur mobile",
      "default": 32
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Épaisseur du titre",
      "options": [
        { "value": "500", "label": "Moyen" },
        { "value": "600", "label": "Semi-gras" },
        { "value": "700", "label": "Gras" },
        { "value": "800", "label": "Très gras" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "heading_line_height",
      "min": 90,
      "max": 150,
      "step": 5,
      "unit": "%",
      "label": "Interligne du titre",
      "default": 115
    },
    {
      "type": "range",
      "id": "heading_line_height_mobile",
      "min": 90,
      "max": 150,
      "step": 5,
      "unit": "%",
      "label": "Interligne du titre sur mobile",
      "default": 115
    },
    {
      "type": "range",
      "id": "heading_letter_spacing",
      "min": -10,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Espacement des lettres",
      "default": -2
    },
    {
      "type": "range",
      "id": "intro_max_width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Largeur du texte d’introduction",
      "default": 800
    },
    {
      "type": "range",
      "id": "intro_margin_top",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Espace sous le titre",
      "default": 15
    },
    {
      "type": "range",
      "id": "intro_size",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Taille du texte d’introduction",
      "default": 18
    },
    {
      "type": "range",
      "id": "intro_size_mobile",
      "min": 13,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Introduction sur mobile",
      "default": 16
    },
    {
      "type": "range",
      "id": "intro_line_height",
      "min": 100,
      "max": 200,
      "step": 5,
      "unit": "%",
      "label": "Interligne de l’introduction",
      "default": 150
    },

    {
      "type": "header",
      "content": "Style des cartes"
    },
    {
      "type": "range",
      "id": "card_min_height",
      "min": 180,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Hauteur minimale",
      "default": 260
    },
    {
      "type": "range",
      "id": "card_min_height_mobile",
      "min": 180,
      "max": 420,
      "step": 10,
      "unit": "px",
      "label": "Hauteur minimale sur mobile",
      "default": 230
    },
    {
      "type": "range",
      "id": "card_padding_x",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Marge intérieure horizontale",
      "default": 45
    },
    {
      "type": "range",
      "id": "card_padding_y",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Marge intérieure verticale",
      "default": 40
    },
    {
      "type": "range",
      "id": "card_padding_x_mobile",
      "min": 15,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Marge horizontale sur mobile",
      "default": 25
    },
    {
      "type": "range",
      "id": "card_padding_y_mobile",
      "min": 15,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Marge verticale sur mobile",
      "default": 30
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Arrondi des cartes",
      "default": 28
    },
    {
      "type": "range",
      "id": "card_border_width",
      "min": 0,
      "max": 6,
      "step": 1,
      "unit": "px",
      "label": "Épaisseur de la bordure",
      "default": 2
    },
