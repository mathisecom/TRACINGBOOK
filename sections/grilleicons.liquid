{% comment %}
  Section : Grille d'icônes avec texte — version corrigée 2
  Fichier conseillé : sections/grille-icones-texte.liquid
{% endcomment %}

<section
  id="icon-text-grid-{{ section.id }}"
  class="itg-section"
  style="
    --itg-background: {{ section.settings.background_color }};
    --itg-text-color: {{ section.settings.text_color }};
    --itg-heading-color: {{ section.settings.heading_color }};
    --itg-card-background: {% if section.settings.enable_card_background %}{{ section.settings.card_background_color }}{% else %}transparent{% endif %};
    --itg-border-color: {{ section.settings.border_color }};
    --itg-border-width: {% if section.settings.enable_border %}{{ section.settings.border_width }}px{% else %}0px{% endif %};
    --itg-radius: {{ section.settings.border_radius }}px;
    --itg-max-width: {{ section.settings.max_width }}px;
    --itg-columns-desktop: {{ section.settings.columns_desktop }};
    --itg-columns-mobile: {% if section.settings.mobile_single_column %}1{% else %}2{% endif %};
    --itg-column-gap: {{ section.settings.column_gap }}px;
    --itg-row-gap: {{ section.settings.row_gap }}px;
    --itg-column-gap-mobile: {{ section.settings.column_gap_mobile }}px;
    --itg-row-gap-mobile: {{ section.settings.row_gap_mobile }}px;
    --itg-icon-size: {{ section.settings.icon_size }}px;
    --itg-icon-size-mobile: {{ section.settings.icon_size_mobile }}px;
    --itg-title-size: {{ section.settings.title_size }}px;
    --itg-title-size-mobile: {{ section.settings.title_size_mobile }}px;
    --itg-subtext-size: {{ section.settings.subtext_size }}px;
    --itg-subtext-size-mobile: {{ section.settings.subtext_size_mobile }}px;
    --itg-item-padding: {{ section.settings.item_padding }}px;
    --itg-item-padding-mobile: {{ section.settings.item_padding_mobile }}px;
    --itg-padding-top: {{ section.settings.padding_top }}px;
    --itg-padding-bottom: {{ section.settings.padding_bottom }}px;
    --itg-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --itg-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --itg-side-padding: {{ section.settings.side_padding }}px;
    --itg-side-padding-mobile: {{ section.settings.side_padding_mobile }}px;
    --itg-heading-align: {{ section.settings.heading_alignment }};
    --itg-heading-size: {{ section.settings.heading_size }}px;
    --itg-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
  "
>
  <div class="itg-container">
    {% if section.settings.heading != blank or section.settings.intro != blank %}
      <div class="itg-header itg-header--{{ section.settings.heading_alignment }}">
        {% if section.settings.heading != blank %}
          <h2 class="itg-heading">{{ section.settings.heading | escape }}</h2>
        {% endif %}

        {% if section.settings.intro != blank %}
          <div class="itg-intro rte">{{ section.settings.intro }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="itg-grid" role="list">
      {% for block in section.blocks %}
        {% assign icon_alt = block.settings.alt_text | default: block.settings.title %}

        {% if block.settings.link != blank %}
          <a
            class="itg-item{% if section.settings.enable_hover %} itg-item--hover{% endif %}{% if section.settings.enable_shadow %} itg-item--shadow{% endif %}"
            href="{{ block.settings.link }}"
            {% if block.settings.open_new_tab %}
              target="_blank"
              rel="noopener noreferrer"
            {% endif %}
            role="listitem"
            {{ block.shopify_attributes }}
          >
        {% else %}
          <div
            class="itg-item{% if section.settings.enable_hover %} itg-item--hover{% endif %}{% if section.settings.enable_shadow %} itg-item--shadow{% endif %}"
            role="listitem"
            {{ block.shopify_attributes }}
          >
        {% endif %}

          {% if block.settings.icon != blank %}
            <div class="itg-icon-wrapper">
              {{
                block.settings.icon
                | image_url: width: 600
                | image_tag:
                  class: 'itg-icon-image',
                  loading: 'lazy',
                  alt: icon_alt
              }}
            </div>
          {% endif %}

          {% if block.settings.title != blank %}
            <div class="itg-title">{{ block.settings.title | escape }}</div>
          {% endif %}

          {% if block.settings.text != blank %}
            <div class="itg-subtext rte">{{ block.settings.text }}</div>
          {% endif %}

        {% if block.settings.link != blank %}
          </a>
        {% else %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% style %}
  #icon-text-grid-{{ section.id }} {
    background: var(--itg-background);
    color: var(--itg-text-color);
    padding-top: var(--itg-padding-top);
    padding-bottom: var(--itg-padding-bottom);
  }

  #icon-text-grid-{{ section.id }} * {
    box-sizing: border-box;
  }

  #icon-text-grid-{{ section.id }} .itg-container {
    width: 100%;
    max-width: var(--itg-max-width);
    margin: 0 auto;
    padding-right: var(--itg-side-padding);
    padding-left: var(--itg-side-padding);
  }

  #icon-text-grid-{{ section.id }} .itg-header {
    margin-bottom: 32px;
    text-align: var(--itg-heading-align);
  }

  #icon-text-grid-{{ section.id }} .itg-heading {
    margin: 0;
    color: var(--itg-heading-color);
    font-size: var(--itg-heading-size);
    line-height: 1.15;
  }

  #icon-text-grid-{{ section.id }} .itg-intro {
    max-width: 760px;
    margin: 12px auto 0;
  }

  #icon-text-grid-{{ section.id }} .itg-header--left .itg-intro {
    margin-right: auto;
    margin-left: 0;
  }

  #icon-text-grid-{{ section.id }} .itg-header--right .itg-intro {
    margin-right: 0;
    margin-left: auto;
  }

  #icon-text-grid-{{ section.id }} .itg-grid {
    display: grid;
    grid-template-columns: repeat(var(--itg-columns-desktop), minmax(0, 1fr));
    column-gap: var(--itg-column-gap);
    row-gap: var(--itg-row-gap);
    align-items: stretch;
  }

  #icon-text-grid-{{ section.id }} .itg-item {
    display: flex;
    min-width: 0;
    height: 100%;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: var(--itg-item-padding);
    border: var(--itg-border-width) solid var(--itg-border-color);
    border-radius: var(--itg-radius);
    background: var(--itg-card-background);
    color: inherit;
    text-align: center;
    text-decoration: none;
  }

  #icon-text-grid-{{ section.id }} .itg-item--shadow {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  #icon-text-grid-{{ section.id }} .itg-icon-wrapper {
    display: flex;
    width: var(--itg-icon-size);
    height: var(--itg-icon-size);
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
  }

  #icon-text-grid-{{ section.id }} .itg-icon-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  #icon-text-grid-{{ section.id }} .itg-title {
    color: var(--itg-text-color);
    font-size: var(--itg-title-size);
    font-weight: {{ section.settings.title_weight }};
    line-height: 1.25;
  }

  #icon-text-grid-{{ section.id }} .itg-subtext {
    margin-top: 8px;
    color: var(--itg-text-color);
    font-size: var(--itg-subtext-size);
    line-height: 1.5;
  }

  #icon-text-grid-{{ section.id }} .itg-subtext > :first-child,
  #icon-text-grid-{{ section.id }} .itg-intro > :first-child {
    margin-top: 0;
  }

  #icon-text-grid-{{ section.id }} .itg-subtext > :last-child,
  #icon-text-grid-{{ section.id }} .itg-intro > :last-child {
    margin-bottom: 0;
  }

  @media (hover: hover) and (pointer: fine) {
    #icon-text-grid-{{ section.id }} .itg-item--hover {
      transition: transform 180ms ease, box-shadow 180ms ease;
    }

    #icon-text-grid-{{ section.id }} .itg-item--hover:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 28px rgba(0, 0, 0, 0.12);
    }
  }

  @media screen and (max-width: 749px) {
    #icon-text-grid-{{ section.id }} {
      padding-top: var(--itg-padding-top-mobile);
      padding-bottom: var(--itg-padding-bottom-mobile);
    }

    #icon-text-grid-{{ section.id }} .itg-container {
      padding-right: var(--itg-side-padding-mobile);
      padding-left: var(--itg-side-padding-mobile);
    }

    #icon-text-grid-{{ section.id }} .itg-header {
      margin-bottom: 24px;
    }

    #icon-text-grid-{{ section.id }} .itg-heading {
      font-size: var(--itg-heading-size-mobile);
    }

    #icon-text-grid-{{ section.id }} .itg-grid {
      grid-template-columns: repeat(var(--itg-columns-mobile), minmax(0, 1fr));
      column-gap: var(--itg-column-gap-mobile);
      row-gap: var(--itg-row-gap-mobile);
    }

    #icon-text-grid-{{ section.id }} .itg-item {
      padding: var(--itg-item-padding-mobile);
    }

    #icon-text-grid-{{ section.id }} .itg-icon-wrapper {
      width: var(--itg-icon-size-mobile);
      height: var(--itg-icon-size-mobile);
      margin-bottom: 10px;
    }

    #icon-text-grid-{{ section.id }} .itg-title {
      font-size: var(--itg-title-size-mobile);
    }

    #icon-text-grid-{{ section.id }} .itg-subtext {
      font-size: var(--itg-subtext-size-mobile);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #icon-text-grid-{{ section.id }} .itg-item--hover {
      transition: none;
    }

    #icon-text-grid-{{ section.id }} .itg-item--hover:hover {
      transform: none;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Icônes avec texte",
  "tag": "section",
  "class": "section-icon-text-grid",
  "max_blocks": 12,
  "settings": [
    {
      "type": "header",
      "content": "En-tête"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre de la section",
      "default": "Nos avantages"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Texte d'introduction"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Alignement",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "Gauche"
        },
        {
          "value": "center",
          "label": "Centre"
        },
        {
          "value": "right",
          "label": "Droite"
        }
      ]
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 64,
      "step": 1,
      "unit": "px",
      "label": "Taille du titre sur ordinateur",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 18,
      "max": 44,
      "step": 1,
      "unit": "px",
      "label": "Taille du titre sur mobile",
      "default": 26
    },
    {
      "type": "header",
      "content": "Mise en page"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "label": "Largeur maximale",
      "default": 1400
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Colonnes sur ordinateur",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "mobile_single_column",
      "label": "Afficher une seule colonne sur mobile",
      "default": false,
      "info": "Désactivé : 2 colonnes sur mobile. Activé : 1 colonne."
    },
    {
      "type": "range",
      "id": "column_gap",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Espacement horizontal sur ordinateur",
      "default": 48
    },
    {
      "type": "range",
      "id": "row_gap",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Espacement vertical sur ordinateur",
      "default": 32
    },
    {
      "type": "range",
      "id": "column_gap_mobile",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Espacement horizontal sur mobile",
      "default": 16
    },
    {
      "type": "range",
      "id": "row_gap_mobile",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Espacement vertical sur mobile",
      "default": 24
    },
    {
      "type": "header",
      "content": "Icônes et textes"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 40,
      "max": 220,
      "step": 5,
      "unit": "px",
      "label": "Taille des icônes sur ordinateur",
      "default": 110
    },
    {
      "type": "range",
      "id": "icon_size_mobile",
      "min": 35,
      "max": 160,
      "step": 5,
      "unit": "px",
      "label": "Taille des icônes sur mobile",
      "default": 80
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Taille du texte sur ordinateur",
      "default": 17
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "min": 10,
      "max": 26,
      "step": 1,
      "unit": "px",
      "label": "Taille du texte sur mobile",
      "default": 14
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Épaisseur du texte",
      "default": "700",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Moyen"
        },
        {
          "value": "600",
          "label": "Semi-gras"
        },
        {
          "value": "700",
          "label": "Gras"
        },
        {
          "value": "800",
          "label": "Très gras"
        }
      ]
    },
    {
      "type": "range",
      "id": "subtext_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Taille du sous-texte sur ordinateur",
      "default": 14
    },
    {
      "type": "range",
      "id": "subtext_size_mobile",
      "min": 9,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Taille du sous-texte sur mobile",
      "default": 12
    },
    {
      "type": "header",
      "content": "Style des éléments"
    },
    {
      "type": "range",
      "id": "item_padding",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Marge intérieure sur ordinateur",
      "default": 12
    },
    {
      "type": "range",
      "id": "item_padding_mobile",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Marge intérieure sur mobile",
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "enable_card_background",
      "label": "Afficher un fond derrière chaque élément",
      "default": false
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Couleur du fond des éléments",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "enable_border",
      "label": "Afficher une bordure",
      "default": false
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 1,
      "max": 5,
      "step": 1,
      "unit": "px",
      "label": "Épaisseur de la bordure",
      "default": 1
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Couleur de la bordure",
      "default": "#e5e5e5"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Arrondi des angles",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "enable_shadow",
      "label": "Afficher une ombre",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_hover",
      "label": "Activer l'effet au survol",
      "default": false
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Couleur de fond de la section",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Couleur du titre de section",
      "default": "#1f1f1f"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur des textes",
      "default": "#1f1f1f"
    },
    {
      "type": "header",
      "content": "Espacement de la section"
    },
    {
      "type": "range",
      "id": "side_padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Marge latérale sur ordinateur",
      "default": 40
    },
    {
      "type": "range",
      "id": "side_padding_mobile",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Marge latérale sur mobile",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Marge supérieure sur ordinateur",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Marge inférieure sur ordinateur",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge supérieure sur mobile",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Marge inférieure sur mobile",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "icon_text",
      "name": "Icône + texte",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icône ou image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Texte principal",
          "default": "Titre de l'icône"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Sous-texte facultatif"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien facultatif"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Ouvrir le lien dans un nouvel onglet",
          "default": false
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Texte alternatif de l'image",
          "info": "Laissez vide pour utiliser le texte principal."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Icônes avec texte",
      "blocks": [
        {
          "type": "icon_text",
          "settings": {
            "title": "Nom personnalisé"
          }
        },
        {
          "type": "icon_text",
          "settings": {
            "title": "Traçage des lettres"
          }
        },
        {
          "type": "icon_text",
          "settings": {
            "title": "Apprentissage des nombres"
          }
        },
        {
          "type": "icon_text",
          "settings": {
            "title": "Apprentissage des formes"
          }
        }
      ]
    }
  ]
}
{% endschema %}