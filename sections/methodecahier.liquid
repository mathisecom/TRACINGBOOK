{%- liquid
  assign image_alt = section.settings.image_alt | strip
  if image_alt == blank and section.settings.image != blank
    assign image_alt = section.settings.image.alt
  endif
-%}

{%- if section.settings.use_grandstander -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Grandstander:wght@400;500;600;700;800&display=swap" rel="stylesheet">
{%- endif -%}

<section class="magic-method magic-method--{{ section.id }}">
  <div class="magic-method__container">
    {%- if section.settings.heading != blank -%}
      <{{ section.settings.heading_tag }} class="magic-method__heading">
        {{ section.settings.heading }}
      </{{ section.settings.heading_tag }}>
    {%- endif -%}

    {%- if section.settings.intro != blank -%}
      <div class="magic-method__intro rte">
        {{ section.settings.intro }}
      </div>
    {%- endif -%}

    <div class="magic-method__layout">
      <div class="magic-method__benefits magic-method__benefits--left">
        {%- for block in section.blocks -%}
          {%- if block.settings.position == 'left' -%}
            <article class="magic-method__benefit" {{ block.shopify_attributes }}>
              {%- if block.settings.icon_image != blank -%}
                <img
                  class="magic-method__icon-image"
                  src="{{ block.settings.icon_image | image_url: width: 160 }}"
                  width="{{ block.settings.icon_image.width }}"
                  height="{{ block.settings.icon_image.height }}"
                  alt=""
                  loading="lazy"
                >
              {%- elsif block.settings.emoji != blank -%}
                <div class="magic-method__emoji" aria-hidden="true">
                  {{ block.settings.emoji }}
                </div>
              {%- endif -%}

              {%- if block.settings.title != blank -%}
                <h3 class="magic-method__benefit-title">
                  {{ block.settings.title | escape }}
                </h3>
              {%- endif -%}

              {%- if block.settings.text != blank -%}
                <div class="magic-method__benefit-text rte">
                  {{ block.settings.text }}
                </div>
              {%- endif -%}
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="magic-method__visual">
        <div class="magic-method__image-wrap">
          {%- if section.settings.image != blank -%}
            <img
              class="magic-method__image"
              src="{{ section.settings.image | image_url: width: 1200 }}"
              srcset="
                {{ section.settings.image | image_url: width: 480 }} 480w,
                {{ section.settings.image | image_url: width: 750 }} 750w,
                {{ section.settings.image | image_url: width: 1000 }} 1000w,
                {{ section.settings.image | image_url: width: 1200 }} 1200w
              "
              sizes="(max-width: 749px) calc(100vw - 36px), 420px"
              width="{{ section.settings.image.width }}"
              height="{{ section.settings.image.height }}"
              alt="{{ image_alt | escape }}"
              loading="lazy"
            >
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'magic-method__placeholder' }}
          {%- endif -%}
        </div>
      </div>

      <div class="magic-method__benefits magic-method__benefits--right">
        {%- for block in section.blocks -%}
          {%- if block.settings.position == 'right' -%}
            <article class="magic-method__benefit" {{ block.shopify_attributes }}>
              {%- if block.settings.icon_image != blank -%}
                <img
                  class="magic-method__icon-image"
                  src="{{ block.settings.icon_image | image_url: width: 160 }}"
                  width="{{ block.settings.icon_image.width }}"
                  height="{{ block.settings.icon_image.height }}"
                  alt=""
                  loading="lazy"
                >
              {%- elsif block.settings.emoji != blank -%}
                <div class="magic-method__emoji" aria-hidden="true">
                  {{ block.settings.emoji }}
                </div>
              {%- endif -%}

              {%- if block.settings.title != blank -%}
                <h3 class="magic-method__benefit-title">
                  {{ block.settings.title | escape }}
                </h3>
              {%- endif -%}

              {%- if block.settings.text != blank -%}
                <div class="magic-method__benefit-text rte">
                  {{ block.settings.text }}
                </div>
              {%- endif -%}
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    {%- if section.settings.button_label != blank -%}
      <div class="magic-method__cta">
        <a
          class="magic-method__button"
          {% if section.settings.button_link != blank %}
            href="{{ section.settings.button_link }}"
          {% else %}
            role="link"
            aria-disabled="true"
          {% endif %}
        >
          {{ section.settings.button_label | escape }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% style %}
  .magic-method--{{ section.id }} {
    --section-bg: {{ section.settings.background_color }};
    --heading-color: {{ section.settings.heading_color }};
    --text-color: {{ section.settings.text_color }};
    --button-bg: {{ section.settings.button_background }};
    --button-color: {{ section.settings.button_text_color }};
    --button-border: {{ section.settings.button_border_color }};
    --button-hover-bg: {{ section.settings.button_hover_background }};
    --button-hover-color: {{ section.settings.button_hover_text_color }};
    --image-radius: {{ section.settings.image_radius }}px;
    --column-gap: {{ section.settings.column_gap }}px;

    width: 100%;
    overflow: hidden;
    background: var(--section-bg);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .magic-method--{{ section.id }} *,
  .magic-method--{{ section.id }} *::before,
  .magic-method--{{ section.id }} *::after {
    box-sizing: border-box;
  }

  {%- if section.settings.use_grandstander -%}
    .magic-method--{{ section.id }} .magic-method__heading,
    .magic-method--{{ section.id }} .magic-method__benefit-title,
    .magic-method--{{ section.id }} .magic-method__button {
      font-family: "Grandstander", sans-serif;
    }
  {%- endif -%}

  .magic-method--{{ section.id }} .magic-method__container {
    width: min(
      calc(100% - ({{ section.settings.side_padding }}px * 2)),
      {{ section.settings.content_width }}px
    );
    margin: 0 auto;
  }

  .magic-method--{{ section.id }} .magic-method__heading {
    max-width: {{ section.settings.heading_max_width }}px;
    margin: 0 auto;
    color: var(--heading-color);
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    line-height: {{ section.settings.heading_line_height | divided_by: 100.0 }};
    letter-spacing: {{ section.settings.heading_letter_spacing | divided_by: 10.0 }}px;
    text-align: center;
  }

  .magic-method--{{ section.id }} .magic-method__intro {
    max-width: {{ section.settings.intro_max_width }}px;
    margin: {{ section.settings.intro_spacing }}px auto 0;
    color: var(--text-color);
    font-size: {{ section.settings.intro_size }}px;
    line-height: {{ section.settings.intro_line_height | divided_by: 100.0 }};
    text-align: center;
  }

  .magic-method--{{ section.id }} .magic-method__intro > :first-child,
  .magic-method--{{ section.id }} .magic-method__benefit-text > :first-child {
    margin-top: 0;
  }

  .magic-method--{{ section.id }} .magic-method__intro > :last-child,
  .magic-method--{{ section.id }} .magic-method__benefit-text > :last-child {
    margin-bottom: 0;
  }

  .magic-method--{{ section.id }} .magic-method__layout {
    display: grid;
    grid-template-columns:
      minmax(0, 1fr)
      minmax(280px, {{ section.settings.image_column_width }}px)
      minmax(0, 1fr);
    gap: var(--column-gap);
    align-items: center;
    margin-top: {{ section.settings.content_spacing }}px;
  }

  .magic-method--{{ section.id }} .magic-method__benefits {
    display: grid;
    gap: {{ section.settings.benefit_gap }}px;
  }

  .magic-method--{{ section.id }} .magic-method__benefit {
    text-align: center;
  }

  .magic-method--{{ section.id }} .magic-method__emoji {
    margin-bottom: {{ section.settings.icon_spacing }}px;
    font-size: {{ section.settings.icon_size }}px;
    line-height: 1;
  }

  .magic-method--{{ section.id }} .magic-method__icon-image {
    display: block;
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    margin: 0 auto {{ section.settings.icon_spacing }}px;
    object-fit: contain;
  }

  .magic-method--{{ section.id }} .magic-method__benefit-title {
    margin: 0;
    color: var(--heading-color);
    font-size: {{ section.settings.benefit_title_size }}px;
    font-weight: {{ section.settings.benefit_title_weight }};
    line-height: {{ section.settings.benefit_title_line_height | divided_by: 100.0 }};
  }

  .magic-method--{{ section.id }} .magic-method__benefit-text {
    max-width: {{ section.settings.benefit_text_width }}px;
    margin: {{ section.settings.benefit_text_spacing }}px auto 0;
    color: var(--text-color);
    font-size: {{ section.settings.benefit_text_size }}px;
    line-height: {{ section.settings.benefit_text_line_height | divided_by: 100.0 }};
  }

  .magic-method--{{ section.id }} .magic-method__image-wrap {
    overflow: hidden;
    border-radius: var(--image-radius);
  }

  .magic-method--{{ section.id }} .magic-method__image,
  .magic-method--{{ section.id }} .magic-method__placeholder {
    display: block;
    width: 100%;
    aspect-ratio: {{ section.settings.image_ratio }};
    object-fit: {{ section.settings.image_fit }};
    object-position: {{ section.settings.image_position }};
    background: {{ section.settings.placeholder_background }};
  }

  .magic-method--{{ section.id }} .magic-method__placeholder {
    padding: 40px;
  }

  .magic-method--{{ section.id }} .magic-method__cta {
    margin-top: {{ section.settings.button_spacing }}px;
    text-align: center;
  }

  .magic-method--{{ section.id }} .magic-method__button {
    display: inline-flex;
    min-height: {{ section.settings.button_height }}px;
    align-items: center;
    justify-content: center;
    padding: 12px {{ section.settings.button_horizontal_padding }}px;
    color: var(--button-color);
    background: var(--button-bg);
    border: {{ section.settings.button_border_width }}px solid var(--button-border);
    border-radius: {{ section.settings.button_radius }}px;
    box-shadow:
      0 {{ section.settings.button_shadow_y }}px
      {{ section.settings.button_shadow_blur }}px
      rgba(0, 0, 0, {{ section.settings.button_shadow_opacity | divided_by: 100.0 }});
    font-size: {{ section.settings.button_text_size }}px;
    font-weight: 700;
    line-height: 1.2;
    text-decoration: none;
    transition:
      transform 180ms ease,
      color 180ms ease,
      background-color 180ms ease;
  }

  .magic-method--{{ section.id }} .magic-method__button:hover {
    color: var(--button-hover-color);
    background: var(--button-hover-bg);
    transform: translateY(-2px);
  }

  .magic-method--{{ section.id }} .magic-method__button[aria-disabled="true"] {
    cursor: default;
    opacity: 0.65;
  }

  @media screen and (max-width: 989px) {
    .magic-method--{{ section.id }} .magic-method__layout {
      grid-template-columns:
        minmax(0, 1fr)
        minmax(260px, {{ section.settings.image_column_width_tablet }}px)
        minmax(0, 1fr);
      gap: {{ section.settings.column_gap_tablet }}px;
    }

    .magic-method--{{ section.id }} .magic-method__heading {
      font-size: {{ section.settings.heading_size_tablet }}px;
    }

    .magic-method--{{ section.id }} .magic-method__benefit-title {
      font-size: {{ section.settings.benefit_title_size_tablet }}px;
    }

    .magic-method--{{ section.id }} .magic-method__benefit-text {
      font-size: {{ section.settings.benefit_text_size_tablet }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .magic-method--{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    .magic-method--{{ section.id }} .magic-method__container {
      width: min(
        calc(100% - ({{ section.settings.side_padding_mobile }}px * 2)),
        {{ section.settings.content_width }}px
      );
    }

    .magic-method--{{ section.id }} .magic-method__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
      line-height: {{ section.settings.heading_line_height_mobile | divided_by: 100.0 }};
    }

    .magic-method--{{ section.id }} .magic-method__intro {
      font-size: {{ section.settings.intro_size_mobile }}px;
    }

    .magic-method--{{ section.id }} .magic-method__layout {
      display: flex;
      flex-direction: column;
      gap: {{ section.settings.mobile_group_gap }}px;
      margin-top: {{ section.settings.content_spacing_mobile }}px;
    }

    .magic-method--{{ section.id }} .magic-method__benefits {
      width: 100%;
      gap: {{ section.settings.benefit_gap_mobile }}px;
    }

    .magic-method--{{ section.id }} .magic-method__visual {
      width: 100%;
      max-width: {{ section.settings.image_width_mobile }}px;
      margin: 0 auto;
    }

    .magic-method--{{ section.id }} .magic-method__emoji {
      margin-bottom: {{ section.settings.icon_spacing_mobile }}px;
      font-size: {{ section.settings.icon_size_mobile }}px;
    }

    .magic-method--{{ section.id }} .magic-method__icon-image {
      width: {{ section.settings.icon_size_mobile }}px;
      height: {{ section.settings.icon_size_mobile }}px;
      margin-bottom: {{ section.settings.icon_spacing_mobile }}px;
    }

    .magic-method--{{ section.id }} .magic-method__benefit-title {
      font-size: {{ section.settings.benefit_title_size_mobile }}px;
    }

    .magic-method--{{ section.id }} .magic-method__benefit-text {
      max-width: 100%;
      font-size: {{ section.settings.benefit_text_size_mobile }}px;
    }

    .magic-method--{{ section.id }} .magic-method__cta {
      margin-top: {{ section.settings.button_spacing_mobile }}px;
    }

    .magic-method--{{ section.id }} .magic-method__button {
      width: {% if section.settings.button_full_width_mobile %}100%{% else %}auto{% endif %};
      font-size: {{ section.settings.button_text_size_mobile }}px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .magic-method--{{ section.id }} .magic-method__button {
      transition: none;
    }

    .magic-method--{{ section.id }} .magic-method__button:hover {
      transform: none;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Méthode Cahier Magique",
  "tag": "section",
  "class": "section-methode-cahier-magique",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Titre",
      "default": "La méthode du Cahier Magique"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Balise du titre",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Introduction"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image centrale"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Texte alternatif de l’image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texte du bouton",
      "default": "JE DÉCOUVRE LE CAHIER ✨"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Lien du bouton"
    },

    {
      "type": "header",
      "content": "Mise en page"
    },
    {
      "type": "range",
      "id": "content_width",
      "min": 900,
      "max": 1800,
      "step": 50,
      "unit": "px",
      "label": "Largeur maximale",
      "default": 1500
    },
    {
      "type": "range",
      "id": "heading_max_width",
      "min": 500,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Largeur du titre",
      "default": 900
    },
    {
      "type": "range",
      "id": "image_column_width",
      "min": 300,
      "max": 600,
      "step": 20,
      "unit": "px",
      "label": "Largeur de l’image",
      "default": 380
    },
    {
      "type": "range",
      "id": "image_column_width_tablet",
      "min": 240,
      "max": 440,
      "step": 20,
      "unit": "px",
      "label": "Largeur de l’image sur tablette",
      "default": 300
    },
    {
      "type": "range",
      "id": "image_width_mobile",
      "min": 260,
      "max": 600,
      "step": 20,
      "unit": "px",
      "label": "Largeur de l’image sur mobile",
      "default": 420
    },
    {
      "type": "range",
      "id": "column_gap",
      "min": 20,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Espace entre les colonnes",
      "default": 60
    },
    {
      "type": "range",
      "id": "column_gap_tablet",
      "min": 15,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Espace sur tablette",
      "default": 30
    },
    {
      "type": "range",
      "id": "content_spacing",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Espace avant le contenu",
      "default": 35
    },
    {
      "type": "range",
      "id": "content_spacing_mobile",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Espace avant le contenu sur mobile",
      "default": 30
    },
    {
      "type": "range",
      "id": "mobile_group_gap",
      "min": 20,
      "max": 70,
      "step": 5,
      "unit": "px",
      "label": "Espace entre les groupes sur mobile",
      "default": 30
    },

    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Format de l’image",
      "options": [
        { "value": "1 / 1", "label": "Carré" },
        { "value": "4 / 5", "label": "Portrait 4:5" },
        { "value": "3 / 4", "label": "Portrait 3:4" },
        { "value": "4 / 3", "label": "Paysage 4:3" }
      ],
      "default": "1 / 1"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Ajustement de l’image",
      "options": [
        { "value": "cover", "label": "Recadrer pour remplir" },
        { "value": "contain", "label": "Afficher l’image entière" }
      ],
      "default": "cover"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Position de l’image",
      "options": [
        { "value": "center center", "label": "Centre" },
        { "value": "center top", "label": "Haut" },
        { "value": "center bottom", "label": "Bas" },
        { "value": "left center", "label": "Gauche" },
        { "value": "right center", "label": "Droite" }
      ],
      "default": "center center"
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Arrondi de l’image",
      "default": 16
    },
    {
      "type": "color",
      "id": "placeholder_background",
      "label": "Fond de démonstration",
      "default": "#e7e2dc"
    },

    {
      "type": "header",
      "content": "Police et titre"
    },
    {
      "type": "checkbox",
      "id": "use_grandstander",
      "label": "Utiliser Grandstander",
      "default": true
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 28,
      "max": 70,
      "step": 2,
      "unit": "px",
      "label": "Taille du titre",
      "default": 42
    },
    {
      "type": "range",
      "id": "heading_size_tablet",
      "min": 26,
      "max": 54,
      "step": 2,
      "unit": "px",
      "label": "Titre sur tablette",
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 24,
      "max": 46,
      "step": 2,
      "unit": "px",
      "label": "Titre sur mobile",
      "default": 32
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Épaisseur du titre",
      "options": [
        { "value": "500", "label": "Moyen" },
        { "value": "600", "label": "Semi-gras" },
        { "value": "700", "label": "Gras" },
        { "value": "800", "label": "Très gras" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "heading_line_height",
      "min": 90,
      "max": 150,
      "step": 5,
      "unit": "%",
      "label": "Interligne du titre",
      "default": 110
    },
    {
      "type": "range",
      "id": "heading_line_height_mobile",
      "min": 90,
      "max": 150,
      "step": 5,
      "unit": "%",
      "label": "Interligne sur mobile",
      "default": 115
    },
    {
      "type": "range",
      "id": "heading_letter_spacing",
      "min": -10,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Espacement des lettres",
      "default": -2
    },
    {
      "type": "range",
      "id": "intro_max_width",
      "min": 400,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "label": "Largeur de l’introduction",
      "default": 700
    },
    {
      "type": "range",
      "id": "intro_spacing",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Espace avant l’introduction",
      "default": 12
    },
    {
      "type": "range",
      "id": "intro_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Taille de l’introduction",
      "default": 17
    },
    {
      "type": "range",
      "id": "intro_size_mobile",
      "min": 13,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Introduction sur mobile",
      "default": 15
    },
    {
      "type": "range",
      "id": "intro_line_height",
      "min": 120,
      "max": 190,
      "step": 5,
      "unit": "%",
      "label": "Interligne de l’introduction",
      "default": 150
    },

    {
      "type": "header",
      "content": "Bénéfices"
    },
    {
      "type": "range",
